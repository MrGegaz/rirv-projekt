# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/

# Logs and OS noise
*.log
.DS_Store

# ML outputs (training artifacts) — keep only models/trained/weights/best.pt
runs/**
models/trained/*
!models/trained/weights/
models/trained/weights/*
!models/trained/weights/best.pt
models/trained_v1_backup/
models/backup_*/

# Large raw / generated data
data/raw/**/*.mp4
data/raw/**/*.avi
data/raw/**/*.mov
data/external/**

# Pretrained weights auto-downloaded by ultralytics in repo root
/yolo*.pt

# Keep folder structure placeholders
!data/**/.gitkeep
!models/**/.gitkeep
